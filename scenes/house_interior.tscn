[sub_resource type="GDScript" id="GDScript_bed"]
script/source = "extends StaticBody3D

func _ready():
	add_to_group(\"interactable\")

func interact():
	Hunger.reset_hunger()
	DialogueManager.show_dialogue([{\"speaker\": \"\", \"text\": \"You rested in the little house. Hunger restored.\"}])

func get_interact_text() -> String:
	return \"Press E to sleep\"
"

[sub_resource type="GDScript" id="GDScript_door"]
script/source = "extends StaticBody3D

func _ready():
	add_to_group(\"interactable\")

func interact():
	var player = get_tree().get_first_node_in_group(\"player\")
	var interior = get_tree().get_first_node_in_group(\"house_interior\")
	if player == null or interior == null:
		return
	player.global_position = interior.exit_position
	player.is_indoors = false
	player.planet_center = Vector3.ZERO
	player.velocity = Vector3.ZERO
	var cam = get_viewport().get_camera_3d()
	if cam:
		var up: Vector3 = player.global_position.normalized()
		cam.global_position = player.global_position + up * 12
	interior.visible = false

func get_interact_text() -> String:
	return \"Press E to exit house\"
"

