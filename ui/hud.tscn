[gd_scene load_steps=2 format=3]

[sub_resource type="GDScript" id="GDScript_1"]
script/source = "extends CanvasLayer

## HUD — Prompts, hunger, held item, planet info, controls, crosshair.

@onready var prompt_label: Label = $PromptLabel
@onready var hunger_bar: ProgressBar = $HungerBar
@onready var hunger_label: Label = $HungerLabel
@onready var held_label: Label = $HeldLabel
@onready var planet_label: Label = $PlanetLabel
@onready var controls_label: Label = $ControlsLabel
@onready var crosshair: Label = $Crosshair
@onready var story_label: Label = $StoryLabel

var _current_planet: String = \"\"
var _story_timer: float = 0.0
var _story_visible: bool = false
var _shown_stories: Dictionary = {}

# Planet names by distance from origin
var _planet_names: Dictionary = {}
var _planet_stories: Dictionary = {
	\"Asteroid B-612\": \"Home. Where your Rose waits.\",
	\"The Desert\": \"The fox is here. Be patient.\",
	\"The King's Planet\": \"A King who only gives reasonable orders.\",
}

func _ready() -> void:
	add_to_group(\"hud\")
	prompt_label.visible = false
	story_label.visible = false
	crosshair.visible = false
	Hunger.hunger_changed.connect(_on_hunger_changed)
	HeldItem.item_held.connect(_on_item_changed)
	HeldItem.item_dropped.connect(_on_item_changed)

	# Map planet positions to names
	await get_tree().create_timer(0.3).timeout
	for planet: Node3D in get_tree().get_nodes_in_group(\"planet\"):
		var pos := planet.global_position
		if pos.length() < 5.0:
			_planet_names[planet] = \"Asteroid B-612\"
		elif planet.name.to_lower().contains(\"desert\"):
			_planet_names[planet] = \"The Desert\"
		elif planet.name.to_lower().contains(\"king\"):
			_planet_names[planet] = \"The King's Planet\"
		else:
			_planet_names[planet] = planet.name

func _process(delta: float) -> void:
	# Update hunger bar
	hunger_bar.value = Hunger.get_hunger_ratio() * 100.0

	# Flash when hungry
	if Hunger.state == Hunger.State.HUNGRY:
		hunger_bar.modulate.a = 0.5 + 0.5 * sin(Time.get_ticks_msec() * 0.01)
		hunger_label.text = \"HUNGRY!\"
		hunger_label.modulate = Color(1, 0.6, 0.2)
	elif Hunger.state == Hunger.State.STARVING:
		hunger_bar.modulate.a = 0.5 + 0.5 * sin(Time.get_ticks_msec() * 0.02)
		hunger_label.text = \"STARVING!\"
		hunger_label.modulate = Color(1, 0.2, 0.2)
	else:
		hunger_bar.modulate.a = 1.0
		hunger_label.text = \"\"
		hunger_label.modulate = Color(1, 1, 1)

	# Update held item display
	if HeldItem.is_empty():
		held_label.text = \"\"
	else:
		held_label.text = \"🤲 \" + HeldItem.current_item_id.replace(\"_\", \" \").capitalize()

	# Update planet label
	_update_planet_info()

	# Update crosshair visibility
	var cam := get_viewport().get_camera_3d()
	if cam and cam.get(\"view_mode\") != null:
		crosshair.visible = (cam.view_mode == 1)  # FIRST_PERSON
	else:
		crosshair.visible = false

	# Controls hint
	var player = get_tree().get_first_node_in_group(\"player\")
	if player and player.get(\"is_in_airplane\") and player.is_in_airplane:
		controls_label.text = \"✈ W/S Speed  A/D Turn  Mouse Steer  E Land\"
	else:
		controls_label.text = \"WASD Move  Space Jump  C Sit  V Camera  E Interact\"

	# Story fade
	if _story_visible:
		_story_timer -= delta
		if _story_timer <= 0.0:
			_story_visible = false
			var tween := create_tween()
			tween.tween_property(story_label, \"modulate:a\", 0.0, 1.0)
			await tween.finished
			story_label.visible = false

func _update_planet_info() -> void:
	var player = get_tree().get_first_node_in_group(\"player\")
	if player == null:
		return

	# Find nearest planet
	var best_planet: Node3D = null
	var best_dist: float = 9999.0
	for planet: Node3D in get_tree().get_nodes_in_group(\"planet\"):
		var dist: float = player.global_position.distance_to(planet.global_position)
		if dist < best_dist:
			best_dist = dist
			best_planet = planet

	if best_planet == null:
		planet_label.text = \"\"
		return

	var planet_name: String = _planet_names.get(best_planet, \"Unknown\")

	# Show planet name and distance
	var radius := 8.0
	for child in best_planet.get_children():
		if child is CollisionShape3D and child.shape is SphereShape3D:
			radius = child.shape.radius
			break

	var surface_dist: float = best_dist - radius
	if surface_dist < 2.0:
		planet_label.text = \"🪐 \" + planet_name
		# Show story when first landing
		if planet_name != _current_planet:
			_current_planet = planet_name
			_show_story(planet_name)
	elif surface_dist < 30.0:
		planet_label.text = \"🪐 \" + planet_name + \" (\" + str(int(surface_dist)) + \"m)\"
	else:
		planet_label.text = \"\"
		_current_planet = \"\"

func _show_story(planet_name: String) -> void:
	if _shown_stories.get(planet_name, false):
		return
	_shown_stories[planet_name] = true

	var story_text: String = _planet_stories.get(planet_name, \"\")
	if story_text.is_empty():
		return

	story_label.text = story_text
	story_label.visible = true
	story_label.modulate.a = 0.0
	_story_visible = true
	_story_timer = 4.0

	var tween := create_tween()
	tween.tween_property(story_label, \"modulate:a\", 1.0, 1.0)

func show_prompt(text: String) -> void:
	prompt_label.text = text
	prompt_label.visible = true

func hide_prompt() -> void:
	prompt_label.visible = false

func _on_hunger_changed(_state_name: String) -> void:
	pass

func _on_item_changed(_item_id: String) -> void:
	pass
"

